generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  password  String
  avatar    String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  workspaceMembers WorkspaceMember[]
  sentWorkspaceInvitations     WorkspaceInvitation[] @relation("WorkspaceInvitationInviter")
  receivedWorkspaceInvitations WorkspaceInvitation[] @relation("WorkspaceInvitationInvitee")
  assignedTasks    Task[]           @relation("TaskAssignee")
  createdTasks     Task[]           @relation("TaskCreator")
  reviewTasks      Task[]           @relation("TaskReviewer")
  picProjects      Project[]        @relation("ProjectPic")
  projectMembers   ProjectMember[]
  projectInvitations ProjectInvitation[]
  comments         Comment[]
  uploadedAttachments TaskAttachment[]
  activityLogs     ActivityLog[]
  taskReviewActions TaskReview[]    @relation("TaskReviewActor")
  taskReviewAssignments TaskReview[] @relation("TaskReviewReviewer")
  notifications    Notification[]         @relation("NotificationUser")
  actedNotifications Notification[]       @relation("NotificationActor")
  notificationPreference NotificationPreference?

  @@map("users")
}

// ─── Workspace ───────────────────────────────────────────────────────────────

model Workspace {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  members  WorkspaceMember[]
  invitations WorkspaceInvitation[]
  projects Project[]

  @@map("workspaces")
}

// ─── Workspace Member (Join Table) ──────────────────────────────────────────

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum WorkspaceInvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model WorkspaceMember {
  id          String        @id @default(uuid())
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now()) @map("joined_at")

  userId      String        @map("user_id")
  workspaceId String        @map("workspace_id")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
  @@index([workspaceId])
  @@map("workspace_members")
}

model WorkspaceInvitation {
  id          String                    @id @default(uuid())
  role        WorkspaceRole             @default(MEMBER)
  status      WorkspaceInvitationStatus @default(PENDING)
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")
  respondedAt DateTime?                 @map("responded_at")

  workspaceId String @map("workspace_id")
  inviterId   String @map("inviter_id")
  inviteeId   String @map("invitee_id")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter   User      @relation("WorkspaceInvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  invitee   User      @relation("WorkspaceInvitationInvitee", fields: [inviteeId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([inviteeId])
  @@index([inviterId])
  @@index([status])
  @@map("workspace_invitations")
}

// ─── Project ─────────────────────────────────────────────────────────────────

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  COMPLETED
}

enum ProjectVisibility {
  PRIVATE
  PUBLIC
}

enum ProjectRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

model Project {
  id          String            @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus     @default(ACTIVE)
  visibility  ProjectVisibility @default(PUBLIC)
  color       String?           @default("#6366f1")
  icon        String?           @default("FolderKanban")
  dueDate     DateTime?         @map("due_date")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  workspaceId String        @map("workspace_id")
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  picId       String?       @map("pic_id")
  pic         User?         @relation("ProjectPic", fields: [picId], references: [id], onDelete: SetNull)

  // Relations
  boards       Board[]
  members      ProjectMember[]
  invitations  ProjectInvitation[]
  activityLogs ActivityLog[]
  labels       ProjectLabel[]

  @@index([workspaceId])
  @@index([picId])
  @@map("projects")
}

// ─── Project Member ──────────────────────────────────────────────────────────

model ProjectMember {
  id        String      @id @default(uuid())
  role      ProjectRole @default(MEMBER)
  joinedAt  DateTime    @default(now()) @map("joined_at")

  userId    String  @map("user_id")
  projectId String  @map("project_id")

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
  @@map("project_members")
}

// ─── Project Invitation ──────────────────────────────────────────────────────

model ProjectInvitation {
  id        String           @id @default(uuid())
  email     String
  token     String           @unique
  role      ProjectRole      @default(MEMBER)
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime         @map("expires_at")
  createdAt DateTime         @default(now()) @map("created_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  inviterId String  @map("inviter_id")
  inviter   User    @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([projectId])
  @@index([email])
  @@map("project_invitations")
}

// ─── Board ───────────────────────────────────────────────────────────────────

model Board {
  id        String   @id @default(uuid())
  name      String   @default("Main Board")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Relations
  columns Column[]

  @@index([projectId])
  @@map("boards")
}

// ─── Column ──────────────────────────────────────────────────────────────────

model Column {
  id        String   @id @default(uuid())
  name      String
  position  Int      @default(0)
  color     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  boardId String @map("board_id")
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  // Relations
  tasks Task[]

  @@index([boardId])
  @@index([boardId, position])
  @@map("columns")
}

// ─── Task ────────────────────────────────────────────────────────────────────

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskApprovalStatus {
  NONE
  IN_REVIEW
  CHANGES_REQUESTED
  APPROVED
}

enum TaskReviewAction {
  SUBMITTED
  APPROVED
  CHANGES_REQUESTED
  CANCELLED
}

model Task {
  id          String       @id @default(uuid())
  title       String
  description String?
  position    Int          @default(0)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  completed   Boolean      @default(false)
  approvalStatus TaskApprovalStatus @default(NONE) @map("approval_status")
  reviewSubmittedAt DateTime? @map("review_submitted_at")
  reviewDueDate DateTime? @map("review_due_date")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  columnId    String  @map("column_id")
  column      Column  @relation(fields: [columnId], references: [id], onDelete: Cascade)

  assigneeId  String? @map("assignee_id")
  assignee    User?   @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId   String  @map("creator_id")
  creator     User    @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)

  reviewerId  String? @map("reviewer_id")
  reviewer    User?   @relation("TaskReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  // Relations
  comments Comment[]
  labels   TaskLabel[]
  attachments TaskAttachment[]
  reviews TaskReview[]

  @@index([columnId])
  @@index([columnId, position])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([reviewerId])
  @@map("tasks")
}

// ─── Task Label ──────────────────────────────────────────────────────────────

model TaskLabel {
  id    String @id @default(uuid())
  name  String
  color String @default("#6366f1")

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_labels")
}

model ProjectLabel {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#6366f1")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  projectId String   @map("project_id")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@index([projectId])
  @@map("project_labels")
}

// ─── Comment ─────────────────────────────────────────────────────────────────

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([authorId])
  @@map("comments")
}

model TaskAttachment {
  id           String   @id @default(uuid())
  fileName     String   @map("file_name")
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  url          String
  createdAt    DateTime @default(now()) @map("created_at")

  taskId       String   @map("task_id")
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  uploaderId   String   @map("uploader_id")
  uploader     User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([uploaderId])
  @@map("task_attachments")
}

model TaskReview {
  id        String           @id @default(uuid())
  action    TaskReviewAction
  comment   String?
  createdAt DateTime         @default(now()) @map("created_at")

  taskId    String @map("task_id")
  task      Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  actorId   String @map("actor_id")
  actor     User   @relation("TaskReviewActor", fields: [actorId], references: [id], onDelete: Cascade)

  reviewerId String? @map("reviewer_id")
  reviewer   User?   @relation("TaskReviewReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([actorId])
  @@index([reviewerId])
  @@map("task_reviews")
}

// ─── Activity Log ────────────────────────────────────────────────────────────

enum ActivityAction {
  CREATED
  UPDATED
  DELETED
  MOVED
  ASSIGNED
  COMMENTED
  COMPLETED
  ARCHIVED
}

model ActivityLog {
  id        String         @id @default(uuid())
  action    ActivityAction
  entity    String         // e.g. "task", "project", "column"
  entityId  String         @map("entity_id")
  metadata  Json?          // Additional context (old/new values, etc.)
  createdAt DateTime       @default(now()) @map("created_at")

  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  projectId String? @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([createdAt])
  @@map("activity_logs")
}

enum NotificationType {
  WORKSPACE_INVITATION
  PROJECT_INVITATION
  TASK_ASSIGNED
  GENERAL
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  title     String
  message   String
  metadata  Json?
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  userId    String           @map("user_id")
  user      User             @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)

  actorId   String?          @map("actor_id")
  actor     User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id             String   @id @default(uuid())
  emailEnabled   Boolean  @default(true) @map("email_enabled")
  pushEnabled    Boolean  @default(true) @map("push_enabled")
  taskAssigned   Boolean  @default(true) @map("task_assigned")
  taskCompleted  Boolean  @default(true) @map("task_completed")
  taskOverdue    Boolean  @default(false) @map("task_overdue")
  projectUpdates Boolean  @default(true) @map("project_updates")
  teamActivity   Boolean  @default(false) @map("team_activity")
  weeklyDigest   Boolean  @default(true) @map("weekly_digest")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  userId         String   @unique @map("user_id")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}
